{
  "manifest_version": 3,
  "name": "llm.extension",
  "version": "0.1.0",
  "description": "Chat with a local LLM server from a Chrome side panel or popup.",
  "background": {
    "service_worker": "src/background.js",
    "type": "module"
  },
  "side_panel": {
    "default_path": "sidepanel.html"
  },
  "action": {
    "default_title": "llm.extension",
    "default_popup": "popup.html"
  },
  "permissions": ["storage", "sidePanel", "unlimitedStorage", "scripting", "activeTab", "tabs"],
  "optional_host_permissions": [
    "http://*/*",
    "https://*/*"
  ]
}
